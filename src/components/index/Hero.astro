---
import { Image } from "astro:assets";
import ensenadaDigital from "../../assets/img/ensenada-baja-california-digitalizandose.png";
import LinkButton from "../ui/LinkButton.astro";
import { SM } from "@/config/social_medias";
---

<section class="w-full bg-white">
  <div
    class="mx-auto max-w-6xl px-4 py-20 grid lg:grid-cols-2 gap-12 items-center"
  >
    <div
      class="relative fade w-full h-full opacity-0 translate-y-4 order-2 overflow-hidden"
    >
      <Image
        src={ensenadaDigital}
        loading="eager"
        class="w-full h-full rounded-xl object-left-bottom object-cover"
        alt="Ensenada Baja California digitalizándose, vista aerea panoramica"
      />
    </div>

    <div
      class="flex flex-col gap-8 fade-scroll-r opacity-0 translate-x-20 transition-all duration-700"
    >
      <div
        class="fade opacity-0 translate-y-4 inline-flex items-center px-4 py-2 rounded-full bg-neutral-100 text-neutral-700 w-fit"
      >
        <address class="not-italic text-sm">Ensenada, Baja California</address>
      </div>

      <h1
        class="fade opacity-0 translate-y-4 text-5xl md:text-7xl font-extrabold tracking-tight leading-[1.05]"
      >
        Software que impulsa
        <br />
        tu negocio<span class="text-black/30 animate-pulse">.</span>
      </h1>

      <p
        class="fade opacity-0 translate-y-4 text-lg text-neutral-700 max-w-xl leading-relaxed"
      >
        En Bahía Labs desarrollamos soluciones a medida para automatizar
        procesos, mejorar tu control de inventario y llevar tu negocio al mundo
        digital.
      </p>

      <div class="fade opacity-0 translate-y-4 flex gap-4 flex-wrap mt-2">
        <LinkButton
          href={SM.whatsapp.link}
          blank={true}
          text="Solicitar consulta"
        >
          <svg
            class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1"
            fill="currentColor"
            viewBox="0 0 256 256"
          >
            <path
              d="M221.66,133.66l-72,72a8,8,0,0,1-11.32-11.32L196.69,136H40a8,8,0,0,1,0-16H196.69L138.34,61.66a8,8,0,0,1,11.32-11.32l72,72Z"
            ></path>
          </svg>
        </LinkButton>

        <LinkButton href="/#services" text="Ver servicios" type="secondary" />
      </div>
    </div>
  </div>
</section>
