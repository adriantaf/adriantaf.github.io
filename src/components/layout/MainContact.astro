---
import LinkButton from "@/components/ui/LinkButton.astro";
import { SM } from "@/config/social_medias";
import Grid from "../ui/Grid.astro";
import GridItem from "../ui/GridItem.astro";
import GridItemIcon from "../ui/GridItemIcon.astro";
import imgContacto from "@/assets/ilustrations/undraw_business-decisions_7vkl.svg";
---

<main class="flex-1 overflow-hidden">
  <section
    class="px-4 py-24 bg-white max-w-5xl mx-auto flex flex-row-reverse flex-wrap justify-center lg:items-center lg:flex-nowrap gap-10"
  >
    <div>
      <span class="text-sm uppercase tracking-wide text-black/50">
        Contacto
      </span>
      <h1
        class="max-w-2xl text-4xl md:text-5xl font-semibold tracking-tight mt-9"
      >
        Cuéntanos tu idea
      </h1>

      <p class="mt-6 text-black/70 max-w-2xl leading-relaxed text-xl">
        Si tienes una idea, un problema o un proceso que quieres mejorar,
        podemos ayudarte a convertirlo en una solución real.
      </p>

      <div class="mt-14 flex flex-col sm:flex-row gap-4 justify-start">
        <LinkButton
          href={SM.whatsapp.link}
          blank={true}
          text="Escríbenos por WhatsApp"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1"
            fill="currentColor"
            viewBox="0 0 256 256"
          >
            <path
              d="M221.66,133.66l-72,72a8,8,0,0,1-11.32-11.32L196.69,136H40a8,8,0,0,1,0-16H196.69L138.34,61.66a8,8,0,0,1,11.32-11.32l72,72Z"
            ></path>
          </svg>
        </LinkButton>

        <LinkButton href={SM.email.link} text="Enviar EMAIL" type="secondary" />
      </div>
    </div>
    <img
      class="max-w-md"
      src={imgContacto.src}
      alt="Ilustración de mensajeria"
    />
  </section>

  <section class="px-4 py-14 bg-white">
    <div class="max-w-5xl mx-auto">
      <Grid cols={2}>
        <GridItem title="Ubicación" description="Ensenada, Baja California">
          <GridItemIcon slot="icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-6 h-6"
              fill="currentColor"
              viewBox="0 0 256 256"
            >
              <path
                d="M232,120h-8.34A96.14,96.14,0,0,0,136,32.34V24a8,8,0,0,0-16,0v8.34A96.14,96.14,0,0,0,32.34,120H24a8,8,0,0,0,0,16h8.34A96.14,96.14,0,0,0,120,223.66V232a8,8,0,0,0,16,0v-8.34A96.14,96.14,0,0,0,223.66,136H232a8,8,0,0,0,0-16Zm-96,87.6V200a8,8,0,0,0-16,0v7.6A80.15,80.15,0,0,1,48.4,136H56a8,8,0,0,0,0-16H48.4A80.15,80.15,0,0,1,120,48.4V56a8,8,0,0,0,16,0V48.4A80.15,80.15,0,0,1,207.6,120H200a8,8,0,0,0,0,16h7.6A80.15,80.15,0,0,1,136,207.6ZM128,88a40,40,0,1,0,40,40A40,40,0,0,0,128,88Zm0,64a24,24,0,1,1,24-24A24,24,0,0,1,128,152Z"
              ></path>
            </svg>
          </GridItemIcon>
        </GridItem>

        <GridItem title="Atención" description="Respuesta en menos de 24 horas">
          <GridItemIcon slot="icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-6 h-6"
              fill="currentColor"
              viewBox="0 0 256 256"
            >
              <path
                d="M216,80H184V48a16,16,0,0,0-16-16H40A16,16,0,0,0,24,48V176a8,8,0,0,0,13,6.22L72,154V184a16,16,0,0,0,16,16h93.59L219,230.22a8,8,0,0,0,5,1.78,8,8,0,0,0,8-8V96A16,16,0,0,0,216,80ZM66.55,137.78,40,159.25V48H168v88H71.58A8,8,0,0,0,66.55,137.78ZM216,207.25l-26.55-21.47a8,8,0,0,0-5-1.78H88V152h80a16,16,0,0,0,16-16V96h32Z"
              ></path>
            </svg>
          </GridItemIcon>
        </GridItem>
      </Grid>
    </div>
  </section>
</main>
