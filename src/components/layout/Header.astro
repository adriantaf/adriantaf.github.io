---
import { Routes } from "../../config/routes";
import LinkButton from "../ui/LinkButton.astro";
import { SM } from "@/config/social_medias";
---

<header
  class="sticky top-0 z-50 backdrop-blur-md bg-white/80 border-b border-black/5"
>
  <div class="max-w-6xl mx-auto px-4 h-20 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <span class="font-black text-xl md:text-lg tracking-tight">
        Bahía Labs<span class="text-black/30">.</span>
      </span>
    </div>

    <nav class="hidden md:flex items-center text-sm font-medium text-black/70">
      <ul class="md:flex items-center gap-8">
        {
          Routes.map((el) => {
            return (
              <li>
                <a href={el.href} class="hover:text-black transition">
                  {el.title}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>

    <div class="flex items-center gap-3">
      <LinkButton
        blank={true}
        href={SM.whatsapp.link}
        text="Cuéntanos tu idea"
        className="px-4 py-2.5"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1"
          fill="currentColor"
          viewBox="0 0 256 256"
          ><path
            d="M88,128a16,16,0,1,1,16,16A16,16,0,0,1,88,128Zm64,16a16,16,0,1,0-16-16A16,16,0,0,0,152,144Zm84-80V192a20,20,0,0,1-20,20H84.47L53,239.17l-.12.11A19.91,19.91,0,0,1,40.05,244a20.14,20.14,0,0,1-8.49-1.9A19.82,19.82,0,0,1,20,224V64A20,20,0,0,1,40,44H216A20,20,0,0,1,236,64Zm-24,4H44V215.23l28.16-24.32A11.93,11.93,0,0,1,80,188H212Z"
          ></path></svg
        >
      </LinkButton>
    </div>
  </div>
</header>
