---
import Grid from "../ui/Grid.astro";
import GridItem from "../ui/GridItem.astro";
import GridItemIcon from "../ui/GridItemIcon.astro";
import imgAboutUs from "@/assets/ilustrations/undraw_sharing-ideas_toje.svg";
---

<main class="flex-1 overflow-hidden">
  <section
    class="px-4 py-24 bg-white max-w-5xl mx-auto flex flex-row flex-wrap justify-center lg:items-center lg:flex-nowrap gap-10"
  >
    <div class="">
      <span class="text-sm uppercase tracking-wide text-black/50">
        Nosotros
      </span>

      <h1 class="text-4xl md:text-5xl font-semibold tracking-tight mt-9">
        Construyendo software con propósito
      </h1>

      <p class="mt-8 text-black/70 leading-relaxed">
        Somos un equipo ensenadense enfocado en ayudar a emprendedores y
        empresas locales a resolver problemas reales mediante soluciones de
        software a la medida.
      </p>

      <p class="mt-4 text-black/70 leading-relaxed">
        Comenzamos escuchando y entendiendo a fondo las necesidades de cada
        cliente y su sector, para desarrollar herramientas que generen
        resultados concretos.
      </p>
    </div>
    <img
      class="max-w-md"
      src={imgAboutUs.src}
      alt="Ilustración de planeacion grupal"
    />
  </section>

  <section class="max-w-5xl mx-auto px-4 py-14 bg-white">
    <Grid cols={2}>
      <GridItem
        title="Misión"
        description="Brindar soluciones de software que se adapten a las necesidades del
          cliente, cambiando el modelo tradicional en el que el cliente se
          adapta al software."
      >
        <GridItemIcon slot="icon">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-6 h-6"
            fill="currentColor"
            viewBox="0 0 256 256"
            ><path
              d="M221.87,83.16A104.1,104.1,0,1,1,195.67,49l22.67-22.68a8,8,0,0,1,11.32,11.32l-96,96a8,8,0,0,1-11.32-11.32l27.72-27.72a40,40,0,1,0,17.87,31.09,8,8,0,1,1,16-.9,56,56,0,1,1-22.38-41.65L184.3,60.39a87.88,87.88,0,1,0,23.13,29.67,8,8,0,0,1,14.44-6.9Z"
            ></path></svg
          >
        </GridItemIcon>
      </GridItem>
      <GridItem
        title="Visión"
        description="Convertir a Ensenada en el principal referente de la transformación
          digital a nivel nacional, impulsando a empresas locales a crecer
          mediante tecnología."
      >
        <GridItemIcon slot="icon">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-6 h-6"
            fill="currentColor"
            viewBox="0 0 256 256"
            ><path
              d="M183.05,56H72A72,72,0,0,0,.08,131.4c1.69,36.69,31.76,66.79,68.45,68.52,15.85.74,32-5.9,49.38-20.3a15.88,15.88,0,0,1,20.24,0C148.72,188.39,165,200,184,200a72,72,0,0,0,72-72.95C255.49,87.87,222.76,56,183.05,56Zm40.81,111.34A55.63,55.63,0,0,1,184,184c-13.88,0-27-9.51-35.65-16.67a31.91,31.91,0,0,0-40.65,0C93.52,179,80.94,184.49,69.28,183.94a56.36,56.36,0,0,1-53.22-53.28A56,56,0,0,1,72,72H183.05c31,0,56.55,24.79,56.95,55.25A55.66,55.66,0,0,1,223.86,167.34ZM184,96a8,8,0,0,1-8,8H80a8,8,0,0,1,0-16h96A8,8,0,0,1,184,96Z"
            ></path></svg
          >
        </GridItemIcon>
      </GridItem>
      <GridItem
        gridCols={2}
        title="Nuestro enfoque"
        dark={true}
        description="No creemos en soluciones genéricas. Cada negocio es distinto, y su
          software también debe serlo. Diseñamos herramientas a la medida que se
          adaptan a tus procesos, no al revés."
      >
        <GridItemIcon slot="icon" dark={true}>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-6 h-6"
            fill="currentColor"
            viewBox="0 0 256 256"
            ><path
              d="M232,48V88a8,8,0,0,1-16,0V56H184a8,8,0,0,1,0-16h40A8,8,0,0,1,232,48ZM72,200H40V168a8,8,0,0,0-16,0v40a8,8,0,0,0,8,8H72a8,8,0,0,0,0-16Zm152-40a8,8,0,0,0-8,8v32H184a8,8,0,0,0,0,16h40a8,8,0,0,0,8-8V168A8,8,0,0,0,224,160ZM32,96a8,8,0,0,0,8-8V56H72a8,8,0,0,0,0-16H32a8,8,0,0,0-8,8V88A8,8,0,0,0,32,96ZM188,167l-56,32a8,8,0,0,1-7.94,0L68,167A8,8,0,0,1,64,160V96a8,8,0,0,1,4-7l56-32a8,8,0,0,1,7.94,0l56,32a8,8,0,0,1,4,7v64A8,8,0,0,1,188,167ZM88.12,96,128,118.79,167.88,96,128,73.21ZM80,155.36l40,22.85V132.64L80,109.79Zm96,0V109.79l-40,22.85v45.57Z"
            ></path></svg
          >
        </GridItemIcon>
      </GridItem>
    </Grid>
  </section>
</main>
